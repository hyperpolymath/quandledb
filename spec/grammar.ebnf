(* SPDX-License-Identifier: PMPL-1.0-or-later *)
(* Copyright (c) 2026 Jonathan D.A. Jewell (hyperpolymath) <j.d.a.jewell@open.ac.uk> *)
(* KRL (Knot Resolution Language) Formal Grammar — EBNF (ISO 14977) *)
(* Designed for QuandleDB v0.2.0 *)
(* Version: 0.1.0 — 2026-03-14 *)
(* @taxonomy: spec/grammar *)

(* ================================================================ *)
(* LEXICAL GRAMMAR                                                   *)
(* ================================================================ *)

(* --- Whitespace and Comments --- *)

whitespace = " " | "\t" | "\n" | "\r" ;
line_comment = "--" , { ? any character except newline ? } ;
block_comment = "{-" , { ? any character ? } , "-}" ;

(* --- Identifiers --- *)

identifier = letter , { letter | digit | "_" | "-" } ;
knot_name = digit , "_" , digit , { digit }                 (* e.g., 3_1, 5_2, 10_139 *)
          | identifier ;                                    (* e.g., trefoil, unknot *)
letter = "a"-"z" | "A"-"Z" | "_" ;
digit = "0"-"9" ;

(* --- Literals --- *)

integer_literal = digit , { digit } ;
float_literal = digit , { digit } , "." , digit , { digit } ;
string_literal = '"' , { ? any character except '"' and '\\' ? | escape } , '"' ;
escape = "\\" , ( "n" | "r" | "t" | "\\" | '"' ) ;
boolean_literal = "true" | "false" ;

literal = integer_literal | float_literal | string_literal | boolean_literal ;

(* --- Keywords --- *)

keyword = "from" | "filter" | "sort" | "take" | "skip" | "return"
        | "where" | "let" | "in" | "as" | "via" | "with"
        | "find_equivalent" | "find_path" | "match"
        | "aggregate" | "group_by" | "count" | "min" | "max" | "avg" | "sum"
        | "and" | "or" | "not"
        | "provenance" | "confidence" | "exact" | "necessary" | "sufficient" | "heuristic"
        | "asc" | "desc"
        | "rule" | "define" | "axiom"
        | "reidemeister" | "isotopy"
        | "equivalences" | "equivalence_class" | "proof"
        | "knots" | "diagrams" | "invariants" ;

(* --- Operators --- *)

(* Comparison *)
op_eq = "==" ;
op_neq = "!=" ;
op_lt = "<" ;
op_le = "<=" ;
op_gt = ">" ;
op_ge = ">=" ;

(* Arithmetic *)
op_plus = "+" ;
op_minus = "-" ;
op_star = "*" ;
op_slash = "/" ;
op_percent = "%" ;

(* Logical *)
op_and = "and" ;
op_or = "or" ;
op_not = "not" ;

(* Special *)
op_pipe = "|" ;
op_arrow = "->" ;
op_fat_arrow = "=>" ;
op_tilde_arrow = "~>" ;      (* path equivalence *)
op_iso = "≅" | "~=" ;        (* propositional equivalence *)
op_def_eq = "==" ;            (* definitional equality *)
op_dot = "." ;
op_colon = ":" ;
op_comma = "," ;
op_semicolon = ";" ;

(* Delimiters *)
lparen = "(" ;
rparen = ")" ;
lbracket = "[" ;
rbracket = "]" ;
lbrace = "{" ;
rbrace = "}" ;

(* ================================================================ *)
(* SYNTACTIC GRAMMAR                                                 *)
(* ================================================================ *)

(* --- Top-Level --- *)

program = { statement } ;

statement = query
          | rule_def
          | let_binding
          | axiom_def ;

(* --- Pipeline Queries --- *)
(*                                                                   *)
(* KRL uses a pipeline syntax inspired by PRQL.                      *)
(* Queries are composed of stages separated by pipe operators.       *)
(*                                                                   *)
(* Example:                                                          *)
(*   from knots                                                      *)
(*   | filter crossing_number <= 10                                  *)
(*   | filter genus == 1                                             *)
(*   | sort jones_polynomial                                         *)
(*   | take 20                                                       *)
(*   | return name, crossing_number, jones_polynomial                *)

query = from_clause , { "|" , pipeline_stage } ;

from_clause = "from" , source ;

source = "knots"                         (* all knots *)
       | "diagrams"                      (* all diagrams *)
       | "invariants"                    (* invariant catalogue *)
       | identifier                      (* named collection *)
       | "(" , query , ")"              (* subquery *)
       | identifier , "as" , identifier  (* aliased source *) ;

pipeline_stage = filter_stage
               | sort_stage
               | take_stage
               | skip_stage
               | return_stage
               | group_stage
               | aggregate_stage
               | equivalence_stage
               | path_stage
               | match_stage
               | with_stage
               | let_stage ;

(* --- Filter --- *)

filter_stage = "filter" , expression ;

(* --- Sort --- *)

sort_stage = "sort" , sort_item , { "," , sort_item } ;
sort_item = expression , [ "asc" | "desc" ] ;

(* --- Take / Skip --- *)

take_stage = "take" , integer_literal ;
skip_stage = "skip" , integer_literal ;

(* --- Return --- *)

return_stage = "return" , return_item , { "," , return_item }
             , [ "with" , "provenance" ] ;

return_item = expression , [ "as" , identifier ]
            | "*"
            | "equivalences"
            | "equivalence_class"
            | "proof" ;

(* --- Group / Aggregate --- *)

group_stage = "group_by" , expression , { "," , expression } ;

aggregate_stage = "aggregate" , aggregate_item , { "," , aggregate_item } ;
aggregate_item = aggregate_fn , "(" , expression , ")" , [ "as" , identifier ] ;
aggregate_fn = "count" | "min" | "max" | "avg" | "sum" ;

(* --- Equivalence Queries --- *)
(*                                                                   *)
(* The core of KRL: queries that find topologically equivalent       *)
(* knots and return the derivation of equivalence.                   *)
(*                                                                   *)
(* Example:                                                          *)
(*   from knots                                                      *)
(*   | find_equivalent "3_1" via [jones, genus]                      *)
(*   | return equivalences with provenance                           *)

equivalence_stage = "find_equivalent" , knot_ref
                  , [ "via" , invariant_list ]
                  , [ "confidence" , ">=" , confidence_level ] ;

knot_ref = knot_name | string_literal | expression ;

invariant_list = "[" , invariant_name , { "," , invariant_name } , "]" ;

invariant_name = "crossing_number" | "writhe" | "genus"
               | "jones" | "jones_polynomial"
               | "alexander" | "alexander_polynomial"
               | "homfly" | "homfly_polynomial"
               | "seifert_genus" | "seifert_circles"
               | "quandle" | "fundamental_quandle"
               | identifier ;

confidence_level = "exact" | "necessary" | "sufficient" | "heuristic" ;

(* --- Path Queries --- *)
(*                                                                   *)
(* Find explicit isotopies (sequences of Reidemeister moves)         *)
(* between knot diagrams.                                            *)
(*                                                                   *)
(* Example:                                                          *)
(*   from diagrams as D                                              *)
(*   | find_path D ~> "3_1" via reidemeister                         *)
(*   | return path, move_count                                       *)

path_stage = "find_path" , expression , "~>" , knot_ref
           , "via" , path_method ;

path_method = "reidemeister"        (* sequence of Reidemeister moves *)
            | "isotopy"             (* ambient isotopy *)
            | identifier ;          (* custom equivalence relation *)

(* --- Graph Pattern Matching --- *)
(*                                                                   *)
(* ASCII-art graph patterns for navigating knot relationships.       *)
(*                                                                   *)
(* Example:                                                          *)
(*   from knots as K1                                                *)
(*   | match (K1)-[:CONNECTED_SUM]->(K2)                             *)
(*   | where K2.crossing_number < K1.crossing_number                 *)

match_stage = "match" , graph_pattern ;

graph_pattern = node_pattern , { edge_pattern , node_pattern } ;

node_pattern = "(" , [ identifier ] , [ ":" , identifier ]
             , [ "{" , property_list , "}" ] , ")" ;

edge_pattern = "-" , "[" , [ ":" , identifier ] , [ "{" , property_list , "}" ] , "]" , "->"
             | "<-" , "[" , [ ":" , identifier ] , [ "{" , property_list , "}" ] , "]" , "-"
             | "-" , "[" , [ ":" , identifier ] , [ "{" , property_list , "}" ] , "]" , "-" ;

property_list = property , { "," , property } ;
property = identifier , ":" , expression ;

(* --- With (modifiers) --- *)

with_stage = "with" , modifier , { "," , modifier } ;
modifier = "provenance"
         | identifier , "=" , expression ;

(* --- Let (inline bindings) --- *)

let_stage = "let" , identifier , "=" , expression ;

(* --- Expressions --- *)
(*                                                                   *)
(*  Precedence (lowest to highest):                                  *)
(*   1. or                                                           *)
(*   2. and                                                          *)
(*   3. not (prefix)                                                 *)
(*   4. ==, !=, <, <=, >, >=, ≅, ~>                                  *)
(*   5. +, -                                                         *)
(*   6. *, /, %                                                      *)
(*   7. - (unary)                                                    *)
(*   8. ., (), []                                                    *)
(*   9. primary                                                      *)

expression = or_expr ;

or_expr = and_expr , { "or" , and_expr } ;
and_expr = not_expr , { "and" , not_expr } ;
not_expr = "not" , not_expr | comparison_expr ;

comparison_expr = additive_expr , [ compare_op , additive_expr ] ;
compare_op = "==" | "!=" | "<" | "<=" | ">" | ">="
           | ( "≅" | "~=" )         (* propositional equivalence *)
           | "~>"                   (* path equivalence *) ;

additive_expr = multiplicative_expr , { ( "+" | "-" ) , multiplicative_expr } ;
multiplicative_expr = unary_expr , { ( "*" | "/" | "%" ) , unary_expr } ;
unary_expr = "-" , unary_expr | postfix_expr ;

postfix_expr = primary_expr , { postfix_op } ;
postfix_op = "." , identifier                     (* field access *)
           | "(" , [ arg_list ] , ")"             (* function call *)
           | "[" , expression , "]" ;             (* index *)

arg_list = expression , { "," , expression } ;

primary_expr = literal
             | knot_name
             | identifier
             | "(" , expression , ")"
             | "[" , [ expression , { "," , expression } ] , "]"  (* array *)
             | "{" , [ property_list ] , "}"                      (* record *)
             | gauss_code_literal ;

(* --- Gauss Code Literals --- *)
(*                                                                   *)
(* Gauss codes are the primary encoding of knot diagrams.            *)
(* Example: gauss(1, -2, 3, -1, 2, -3)                              *)

gauss_code_literal = "gauss" , "(" , signed_integer
                   , { "," , signed_integer } , ")" ;

signed_integer = [ "-" ] , integer_literal ;

(* --- Rule Definitions --- *)
(*                                                                   *)
(* Datalog-style rules for defining equivalence relations.           *)
(*                                                                   *)
(* Example:                                                          *)
(*   rule jones_equivalent(K1, K2) :-                                *)
(*     knot(K1), knot(K2),                                           *)
(*     jones_polynomial(K1, J), jones_polynomial(K2, J),             *)
(*     K1 != K2                                                      *)

rule_def = "rule" , identifier , "(" , param_list , ")" , ":-"
         , rule_body ;

param_list = identifier , { "," , identifier } ;

rule_body = rule_clause , { "," , rule_clause } ;

rule_clause = identifier , "(" , arg_list , ")"   (* predicate application *)
            | expression ;                         (* guard expression *)

(* --- Let Bindings (top-level) --- *)

let_binding = "let" , identifier , [ ":" , type_annotation ] , "=" , expression ;

(* --- Axiom Definitions --- *)
(*                                                                   *)
(* Axioms declare mathematical facts that KRL can use in proofs.     *)
(*                                                                   *)
(* Example:                                                          *)
(*   axiom reidemeister_preserves_invariants :                        *)
(*     forall K1 K2, reidemeister_equivalent(K1, K2) ->              *)
(*     jones_polynomial(K1) == jones_polynomial(K2)                  *)

axiom_def = "axiom" , identifier , ":" , axiom_body ;

axiom_body = [ "forall" , param_list , "," ]
           , expression , "->" , expression ;

(* --- Type Annotations --- *)
(*                                                                   *)
(* KRL types reflect the mathematical structures of knot theory.     *)

type_annotation = "Int" | "Float" | "String" | "Bool"
                | "Knot" | "Diagram" | "Invariant"
                | "Polynomial"                          (* Laurent polynomial *)
                | "GaussCode"                           (* Gauss code encoding *)
                | "Quandle"                             (* Algebraic quandle *)
                | "Equivalence" , "[" , type_annotation , "]"  (* Space of equivalences *)
                | "Equivalence" , "[" , type_annotation , "," , confidence_level , "]"
                                                        (* Confidence-indexed equivalence *)
                | "Option" , "[" , type_annotation , "]"
                | "List" , "[" , type_annotation , "]"
                | "Set" , "[" , type_annotation , "]"
                | "Map" , "[" , type_annotation , "," , type_annotation , "]"
                | "ResultSet" , "[" , type_annotation , "]"   (* Query result set *)
                | "Provenance"                          (* Provenance annotation *)
                | identifier                            (* User-defined type *)
                | "(" , type_annotation , { "," , type_annotation } , ")" ;  (* tuple *)

(* ================================================================ *)
(* SQL COMPATIBILITY SYNTAX                                          *)
(* ================================================================ *)
(*                                                                   *)
(* KRL accepts a subset of SQL as an alternative front-end syntax.   *)
(* SQL queries are mechanically translated to KRL pipelines.         *)
(*                                                                   *)
(* Example:                                                          *)
(*   SELECT name, crossing_number FROM knots                         *)
(*   WHERE crossing_number <= 10 ORDER BY name LIMIT 20              *)
(*                                                                   *)
(* Translates to:                                                    *)
(*   from knots | filter crossing_number <= 10                       *)
(*   | sort name | take 20 | return name, crossing_number            *)

sql_query = "SELECT" , sql_select_list , "FROM" , sql_source
          , [ "WHERE" , sql_where ]
          , [ "GROUP" , "BY" , sql_group_by ]
          , [ "HAVING" , expression ]
          , [ "ORDER" , "BY" , sql_order_by ]
          , [ "LIMIT" , integer_literal ]
          , [ "OFFSET" , integer_literal ]
          , ";" ;

sql_select_list = "*"
                | sql_select_item , { "," , sql_select_item } ;

sql_select_item = expression , [ "AS" , identifier ]
                | aggregate_fn , "(" , expression , ")" , [ "AS" , identifier ] ;

sql_source = "knots" | "diagrams" | "invariants" | identifier ;

sql_where = expression ;

sql_group_by = expression , { "," , expression } ;

sql_order_by = sql_order_item , { "," , sql_order_item } ;
sql_order_item = expression , [ "ASC" | "DESC" ] ;
